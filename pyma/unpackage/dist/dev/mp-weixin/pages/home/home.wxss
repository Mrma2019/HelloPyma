.box {
  width: 100%;
  justify-content: center;
  background-color: #1A4190;
  flex-shrink: 0;
}
.box .swiper {
  position: relative;
  width: 95%;
  border-radius: 10rpx;
  overflow: hidden;
}
@media screen and (min-width: 768px) {
.box .swiper {
    height: 200rpx;
}
}
.box .swiper .image {
  width: 100%;
  height: 100%;
}
.content-panel {
  width: 95%;
}
.content-panel .weather-card {
  height: 200rpx;
  justify-content: space-between;
  box-sizing: border-box;
  overflow: hidden;
}
.content-panel .weather-card .weather-card__info {
  width: -webkit-max-content;
  width: max-content;
  position: relative;
  padding: 15rpx 25rpx;
  background-color: #fff;
  border-radius: 10rpx;
  justify-content: center;
  align-items: center;
  color: #1A4190;
}
.content-panel .weather-card .weather-card__info .weather-card__icon-row {
  align-items: flex-end;
}
.content-panel .weather-card .weather-card__info .weather-card__icon-row .weather-card__weather-icon {
  font-size: 90rpx;
  color: #E6DB74;
}
.content-panel .weather-card .weather-card__info .weather-card__icon-row .weather-card__temp {
  font-size: 60rpx;
}
.content-panel .weather-card .weather-card__info .weather-card__icon-row .weather-card__temp-icon {
  font-size: 35rpx;
  font-weight: bold;
}
.content-panel .weather-card .weather-card__info .weather-card__icon-row .weather-card__time {
  font-size: 22rpx;
}
.content-panel .weather-card .weather-card__info .weather-card__info-col {
  align-items: center;
  font-size: 23rpx;
}
.content-panel .weather-card .weather-card__date {
  flex: 1;
  margin-left: 10px;
  background-color: #fff;
  border-radius: 10rpx;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
  padding: 20rpx;
  position: relative;
}
.content-panel .weather-card .weather-card__date .title {
  color: #1A4190;
  font-size: 22rpx;
  margin: 20rpx;
  position: absolute;
  top: 0;
}
.content-panel .weather-card .weather-card__date .date {
  width: 90%;
  justify-content: space-between;
}
.content-panel .weather-card .weather-card__date .date .date-item {
  width: 28%;
  background-color: #1A4190;
  color: #fff;
  padding: 18rpx 0;
  font-size: 35rpx;
  text-align: center;
  position: relative;
}
.content-panel .weather-card .weather-card__date .date .date-item .desc {
  font-size: 18rpx;
  position: absolute;
  right: 8rpx;
  bottom: 5rpx;
}
.content-panel .weather-card .breath {
  animation: breath 2s ease-in-out infinite;
}
@keyframes breath {
0% {
    transform: scale(1);
    opacity: 1;
}
50% {
    transform: scale(1.1);
    opacity: 0.6;
}
100% {
    transform: scale(1);
    opacity: 1;
}
}
.content-panel .btn-card {
  height: 250rpx;
  justify-content: space-between;
  background-color: #fff;
  margin-top: 10px;
  border-radius: 10rpx;
  padding: 20rpx;
  box-sizing: border-box;
  overflow: hidden;
  color: #fff;
}
.content-panel .btn-card .btn {
  position: relative;
  box-sizing: border-box;
  overflow: hidden;
  justify-content: center;
  background-color: #1A4190;
  border-radius: 10rpx;
}
.content-panel .btn-card .text {
  font-size: 32rpx;
  margin: 0 0 25rpx 40rpx;
}
.content-panel .btn-card .desc {
  font-size: 20rpx;
  margin: 20rpx 0 0 40rpx;
}
.content-panel .btn-card .iconfont {
  font-size: 50rpx;
  position: absolute;
  right: 25rpx;
  bottom: 25rpx;
}
.content-panel .btn-card .btn-card__main {
  width: 49%;
  height: 100%;
}
.content-panel .btn-card .btn-card__box {
  width: 49%;
  height: 100%;
  justify-content: space-between;
}
.content-panel .btn-card .btn-card__box .btn-card__sub {
  width: 100%;
  height: 49%;
}
.content-panel .btn-card .btn-card__box .btn-card__sub .text {
  margin: 0 0 10rpx 25rpx;
}
.content-panel .btn-card .btn-card__box .btn-card__sub .desc {
  margin: 0 0 0 25rpx;
}