 .nav-bar {
  background-color: #f8f8f8 !important;
}
.profile-card {
  width: 95%;
  height: -webkit-max-content;
  height: max-content;
  background-color: #1A4190;
  border-radius: 20rpx;
  color: #fff;
}
.profile-card .avatar-wrapper {
  align-items: center;
  padding: 20rpx;
  position: relative;
}
.profile-card .avatar {
  width: 100rpx;
  height: 100rpx;
  margin-left: 20rpx;
  border-radius: 20rpx;
  border: 2px solid #fff;
}
.profile-card .nickname {
  padding-left: 40rpx;
}
.profile-card .menu-btn {
  width: 40rpx;
  height: 40rpx;
  display: inline-block;
  position: absolute;
  right: 40rpx;
  background-color: #fff;
  border-radius: 50%;
  color: #1A4190;
  text-align: center;
  line-height: 40rpx;
  box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.5);
  transition: transform 0.25s ease-out;
  will-change: transform;
}
.profile-card .menu-btn:hover {
  transform: scale(1.2);
}